# BuildChatBot configuration — copy to env.local and fill in.
# Lines starting with # are comments. Blank values fall back to appsettings.json defaults.

# --- Telegram ---
# Bot token from @BotFather
TELEGRAM_BOT_TOKEN=
# API ID + Hash from https://my.telegram.org (required by WTelegramBot for >50 MB uploads)
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
# Files at or above this size (MB) are sent via WTelegramBot instead of the Bot API.
TELEGRAM_LARGE_FILE_THRESHOLD_MB=49

# --- Repository (existing local Flutter project) ---
REPO_PATH=
REPO_BRANCH=master
REPO_REMOTE_NAME=origin
# Optional SSH credentials for LibGit2Sharp pulls against private repos
REPO_SSH_KEY_PATH=
REPO_SSH_PUBKEY_PATH=
REPO_SSH_PASSPHRASE=

# --- Flutter / build flags ---
FLUTTER_BIN=flutter
FLUTTER_TARGET_PLATFORM=android-arm64
# Leave blank if your project has no flavors
FLUTTER_FLAVOR=
# Optional alternate entrypoint, e.g. lib/main_dev.dart
FLUTTER_TARGET_FILE=
# Extra args appended verbatim to `flutter build apk`
FLUTTER_EXTRA_ARGS=
FLUTTER_RUN_PUB_GET=true
FLUTTER_RUN_CLEAN=true

# --- Android toolchain ---
JAVA_HOME=
ANDROID_SDK_ROOT=
# Blank → autodetect under ANDROID_SDK_ROOT/build-tools/<latest>
APKSIGNER_PATH=

# --- Artifact paths (relative to REPO_PATH for APK, working dir for caches) ---
APK_OUTPUT_RELATIVE=build/app/outputs/flutter-apk/app-release.apk
APK_CACHE_DIR=./cache/apks
TEMP_DIR_BASE=./tmp

# --- Runtime behavior ---
HEARTBEAT_SECONDS=30
QUEUE_CAPACITY=10
GRADLE_CLEAN_EVERY_N_BUILDS=20
LOG_DIR=./logs
BUILD_RECORD_PATH=./logs/builds.jsonl
